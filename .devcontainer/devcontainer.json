{
  "name": "Full Weatherline Widget",
  "image": "mcr.microsoft.com/devcontainers/base:debian",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y git-lfs ripgrep && git lfs install && npm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "actboy168.tasks", 
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  }
}